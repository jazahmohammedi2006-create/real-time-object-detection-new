<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/17" 
            xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="com.objectdetection.gui.MainController"
            prefWidth="1200" prefHeight="800"
            style="-fx-padding: 10; -fx-background-color: #f4f4f4;">

    <top>
        <VBox spacing="15">
            <Label text="Real-Time Object Detection System" 
                   style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

            <HBox spacing="15" alignment="CENTER_LEFT">
                <VBox spacing="5">
                    <Label text="Detection Controls" style="-fx-font-weight: bold;"/>
                    <HBox spacing="10">
                        <Button fx:id="startButton" text="Start Detection" 
                                style="-fx-background-color: #27ae60; -fx-text-fill: white;"/>
                        <Button fx:id="stopButton" text="Stop Detection" 
                                style="-fx-background-color: #e74c3c; -fx-text-fill: white;"/>
                    </HBox>
                </VBox>

                <VBox spacing="5">
                    <Label text="Dataset ^& Training" style="-fx-font-weight: bold;"/>
                    <HBox spacing="10">
                        <Button fx:id="captureButton" text="Capture Image"/>
                        <Button fx:id="trainButton" text="Train Model"/>
                    </HBox>
                </VBox>

                <VBox spacing="5">
                    <Label text="Object Class" style="-fx-font-weight: bold;"/>
                    <ComboBox fx:id="classSelector" prefWidth="120"/>
                </VBox>
            </HBox>

            <HBox spacing="20" alignment="CENTER_LEFT">
                <Label fx:id="statusLabel" text="Status: Ready" 
                       style="-fx-font-weight: bold; -fx-text-fill: #2980b9;"/>
                <VBox spacing="5">
                    <Label text="Training Progress"/>
                    <ProgressBar fx:id="trainingProgress" prefWidth="200"/>
                </VBox>
            </HBox>
        </VBox>
    </top>

    <center>
        <SplitPane dividerPositions="0.7">
            <VBox spacing="10">
                <Label text="Live Camera Feed" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                <ImageView fx:id="cameraView" 
                          fitWidth="800" 
                          fitHeight="600" 
                          preserveRatio="true"
                          style="-fx-border-color: #bdc3c7; -fx-border-width: 2px;"/>
            </VBox>

            <VBox spacing="10">
                <Label text="System Log" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                <TextArea fx:id="logArea" 
                         prefWidth="350" 
                         prefHeight="600"
                         editable="false"
                         style="-fx-font-family: 'Consolas'; -fx-font-size: 12px;"/>
            </VBox>
        </SplitPane>
    </center>
</BorderPane>
